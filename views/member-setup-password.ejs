<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Set Password | Kinger Matrimonials</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/logo-mark.svg" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="theme-shell">
  <div class="auth-shell">
    <section class="auth-copy">
      <div class="auth-brand-wrap">
        <a class="brand" href="/" aria-label="Kinger Matrimonials home">
          <img class="brand-mark" src="/logo-mark.svg" alt="Kinger Matrimonials logo" />
          <img class="brand-wordmark" src="/logo-wordmark.svg" alt="Kinger Matrimonials" />
        </a>
      </div>
      <p class="eyebrow">Activate Member Access</p>
      <h1>Create your password after approval.</h1>
      <p>Once your password is set, you can log in with your email and view approved profiles anytime.</p>
    </section>

    <section class="login-box elevated-card">
      <h2>Set Password</h2>
      <p class="muted-text">Choose a password with at least 6 characters.</p>

      <input id="password" type="password" placeholder="New password" />
      <input id="confirmPassword" type="password" placeholder="Confirm password" />
      <p id="setupMessage" class="muted-text"></p>

      <button onclick="setupPassword()" class="primary-button full-width">Save Password</button>
    </section>
  </div>

  <script>
    const setupToken = "<%= token %>";

    async function setupPassword() {
      const message = document.getElementById("setupMessage");
      message.innerText = "";

      if (!setupToken) {
        message.innerText = "Setup link is missing or invalid.";
        return;
      }

      if (password.value !== confirmPassword.value) {
        message.innerText = "Passwords do not match.";
        return;
      }

      const res = await fetch("/api/member/setup-password", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          token: setupToken,
          password: password.value,
        }),
      });

      const data = await res.json();

      if (res.ok) {
        window.location.href = "/member/login";
        return;
      }

      message.innerText = data.error || "Password setup failed";
    }
  </script>
</body>
</html>
