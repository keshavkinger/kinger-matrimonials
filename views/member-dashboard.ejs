<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Member Dashboard | Kinger Matrimonials</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/logo-mark.svg" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="theme-shell">
  <div class="page-shell private-page">
    <nav class="site-nav compact-nav member-nav">
      <a class="brand" href="/" aria-label="Kinger Matrimonials home">
        <img class="brand-mark" src="/logo-mark.svg" alt="Kinger Matrimonials logo" />
        <img class="brand-wordmark" src="/logo-wordmark.svg" alt="Kinger Matrimonials" />
      </a>
      <div class="nav-links">
        <a href="/member/edit?token=<%= token %>">Edit Profile</a>
        <a href="/profiles?token=<%= token %>">Approved Profiles</a>
        <button type="button" class="ghost-button" onclick="memberLogout()">Logout</button>
      </div>
    </nav>

    <section class="member-dashboard-hero">
      <div class="member-hero-copy">
        <p class="eyebrow">Member Dashboard</p>
        <h1>Welcome back, <%= member.fullName %>.</h1>
        <p>Your profile is approved and active. You can review your own details below and browse the full member gallery anytime.</p>
        <div class="hero-actions">
          <a href="/profiles?token=<%= token %>" class="primary-button">Browse Approved Profiles</a>
          <a href="/member/edit?token=<%= token %>" class="secondary-button">Edit My Profile</a>
          <a href="/<%= member.biodata %>" target="_blank" class="secondary-button">Open My Biodata</a>
        </div>
      </div>

      <div class="dashboard-stats">
        <div class="stat-card">
          <span class="stat-label">Status</span>
          <strong>Approved</strong>
        </div>
        <div class="stat-card">
          <span class="stat-label">Approved Members</span>
          <strong><%= approvedCount %></strong>
        </div>
        <div class="stat-card">
          <span class="stat-label">Preferred Contact</span>
          <strong><%= member.contactPreference || "Email" %></strong>
        </div>
        <div class="stat-card">
          <span class="stat-label">Saved Profiles</span>
          <strong><%= shortlistProfiles.length %></strong>
        </div>
      </div>
    </section>

    <section class="member-dashboard-grid">
      <article class="info-card">
        <p class="section-kicker">Your Profile</p>
        <h2>Core details</h2>
        <div class="member-detail-list">
          <div><strong>Age:</strong> <span><%= member.age %></span></div>
          <div><strong>Height:</strong> <span><%= member.height %></span></div>
          <div><strong>Gender:</strong> <span><%= member.gender %></span></div>
          <div><strong>Religion:</strong> <span><%= member.religion %></span></div>
          <div><strong>Mother Tongue:</strong> <span><%= member.motherTongue %></span></div>
          <div><strong>City:</strong> <span><%= member.city %></span></div>
          <div><strong>Education:</strong> <span><%= member.education %></span></div>
          <div><strong>Occupation:</strong> <span><%= member.occupation %></span></div>
          <div><strong>Income:</strong> <span><%= member.income %></span></div>
          <div><strong>Marital Status:</strong> <span><%= member.maritalStatus %></span></div>
          <div><strong>Family Type:</strong> <span><%= member.familyType %></span></div>
          <div><strong>Phone:</strong> <span><%= member.phone %></span></div>
          <div><strong>WhatsApp:</strong> <span><%= member.whatsappNumber %></span></div>
        </div>
      </article>

      <article class="info-card">
        <p class="section-kicker">Partner Preferences</p>
        <h2>What you are looking for</h2>
        <p class="profile-requirements"><%= member.requirements %></p>
      </article>
    </section>

    <section class="member-gallery-card">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Photo Gallery</p>
          <h2>Your submitted photos</h2>
        </div>
      </div>

      <div class="member-photo-strip">
        <% (member.photos && member.photos.length ? member.photos : [member.photo]).forEach((photo) => { %>
          <div class="member-photo-tile">
            <img src="/<%= photo %>" alt="<%= member.fullName %>" />
          </div>
        <% }) %>
      </div>
    </section>

    <section class="member-dashboard-grid">
      <article class="info-card">
        <p class="section-kicker">Recommended For You</p>
        <h2>Best matching profiles</h2>
        <div class="dashboard-mini-grid">
          <% recommendations.forEach((profile) => { %>
            <a href="/profiles/<%= profile._id %>?token=<%= token %>" class="mini-match-card">
              <img src="/<%= profile.photo %>" alt="<%= profile.fullName %>" />
              <div>
                <strong><%= profile.fullName %></strong>
                <span><%= profile.city %> · <%= profile.religion %></span>
              </div>
            </a>
          <% }) %>
          <% if (!recommendations.length) { %>
            <p class="muted-text">More recommendations will appear as approved members grow.</p>
          <% } %>
        </div>
      </article>

      <article class="info-card">
        <p class="section-kicker">Shortlisted Profiles</p>
        <h2>Profiles you saved</h2>
        <div class="dashboard-mini-grid">
          <% shortlistProfiles.forEach((profile) => { %>
            <a href="/profiles/<%= profile._id %>?token=<%= token %>" class="mini-match-card">
              <img src="/<%= profile.photo %>" alt="<%= profile.fullName %>" />
              <div>
                <strong><%= profile.fullName %></strong>
                <span><%= profile.city %> · <%= profile.occupation || "Profile" %></span>
              </div>
            </a>
          <% }) %>
          <% if (!shortlistProfiles.length) { %>
            <p class="muted-text">Save profiles from the approved gallery and they will appear here.</p>
          <% } %>
        </div>
      </article>
    </section>
  </div>

  <script>
    function memberLogout() {
      localStorage.removeItem("memberToken");
      window.location.href = "/member/login";
    }
  </script>
</body>
</html>
