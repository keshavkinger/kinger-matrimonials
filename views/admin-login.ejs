<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | Kinger Matrimonials</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="theme-shell">
  <div class="auth-shell">
    <section class="auth-copy">
      <p class="eyebrow">Admin Access</p>
      <h1>Review submissions with a cleaner workflow.</h1>
      <p>Sign in to approve profiles, reject entries, manage files, and keep the platform updated.</p>
    </section>

    <section class="login-box elevated-card">
      <h2>Admin Login</h2>
      <p class="muted-text">Use your admin credentials to continue.</p>

      <input id="username" placeholder="Username" />
      <input id="password" type="password" placeholder="Password" />

      <button onclick="login()" class="primary-button full-width">Login</button>
    </section>
  </div>

<script>
  async function login() {
    const res = await fetch("/api/admin/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        username: username.value,
        password: password.value,
      }),
    });

    const data = await res.json();

    if (data.token) {
      localStorage.setItem("token", data.token);

      // ✅ Pass token in URL
      window.location.href = "/admin/dashboard?token=" + data.token;
    } else {
      alert("Login failed");
    }
  }
</script>

</body>
</html>
